# Lambda environment variables — copy to .env and fill in real values.
# .env is gitignored; this file is safe to commit.

CONTACT_EMAIL=aiuc@purestorage.com

# Email domain validation
# APPROVAL_EMAIL: where to send pending-approval notifications.
# Defaults to CONTACT_EMAIL if not set.
APPROVAL_EMAIL=your-approval-alias@company.com

# WHITELIST_DOMAINS: comma-separated list of pre-approved enterprise domains.
# Users from these domains skip the approval flow entirely.
# Format: "company1.com,company2.com,agency.org"
WHITELIST_DOMAINS=""

# AI domain classification (Google Gemini)
# Get a free key at: https://aistudio.google.com/app/apikey 
GEMINI_API_KEY=AIzaSyDEpGPZm1kJWTrlbFKhTmmT6GlqHNlJr3o

# Approval flow
# APP_URL: public base URL of your app (used in approval email links)
APP_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws
# APPROVAL_SECRET: random string used to sign approval tokens — keep this secret
APPROVAL_SECRET=change-me-to-a-random-stringAIzaSyDEpGPZm1kJWTrlbFKhTmmT6GlqHNlJr3o

# SMTP settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=youremail@gmail.com
