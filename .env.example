# ── AIUC — Environment Variables Reference (Spearhead deployment) ─────────────
# Copy this file to .env.local for local development and fill in real values.
# .env.local is gitignored — never commit real credentials.
# Lambda runtime variables are set in the AWS Lambda Console, not here.

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite build-time — prefix VITE_)
# These are baked into the compiled frontend bundle at npm run build time.
# ─────────────────────────────────────────────────────────────────────────────

# Cognito user pool (frontend SDK config)
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=us-east-1

# Local dev only — Vite proxies /api/* to this URL
VITE_API_BASE_URL=http://localhost:3001

# Optional: deploy at a sub-path (e.g. behind an ALB at /app/aiuc)
# Leave unset for standard Lambda Function URL deployment at root /
# VITE_BASE_PATH=/app/aiuc

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV SERVER (lambda/local-server.mjs only — not used in Lambda)
# ─────────────────────────────────────────────────────────────────────────────

# AWS profile to use for Bedrock and S3 calls during local dev
AWS_PROFILE=your-aws-profile
AWS_REGION=us-east-1

# ─────────────────────────────────────────────────────────────────────────────
# LAMBDA RUNTIME — set in AWS Lambda Console (not in this file for production)
# Documented here for reference.
# ─────────────────────────────────────────────────────────────────────────────

# S3 / Storage
# BUCKET_NAME=spearhead-aiuc-bucket
# S3_REGION=us-east-1
# DIST_PREFIX=dist
# LOG_PREFIX=logs

# S3 keys for pre-computed Bedrock Titan embeddings
# (run scripts/generate-embeddings.mjs locally, then upload these JSON files to S3)
# USE_CASES_EMBEDDINGS_KEY=use_cases_embeddings.json
# INDUSTRY_EMBEDDINGS_KEY=industry_use_cases_embeddings.json

# Cognito authentication (Lambda JWT verification — server-side)
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI search feature flag
# Set to "false" to disable semantic search and fall back to keyword matching only.
# Any other value (or omitting the variable) enables AI search.
# ENABLE_AI_SEARCH=true

# Approval workflow
# APPROVAL_SECRET=a-long-random-secret-used-to-sign-approval-tokens
# APP_URL=https://your-lambda-function-url.lambda-url.us-east-1.on.aws

# SES email (cross-account role for sending registration/contact emails)
# SES_FROM_EMAIL=noreply@yourdomain.com
# CONTACT_EMAIL=aiuc@spearhead.so
# APPROVAL_EMAIL=admin@spearhead.so
# SES_CROSS_ACCOUNT_ROLE_ARN=arn:aws:iam::123456789012:role/ses-send-role

# Column visibility: comma-separated column display names to blank out for unauthenticated users
# USE_CASE_RESTRICTED_COLUMNS=AI Algorithms & Frameworks,Datasets,Action / Implementation,AI Tools & Models,Digital Platforms and Tools
# INDUSTRY_RESTRICTED_COLUMNS=Implementation Plan,Datasets,AI Tools / Platforms,Digital Tools / Platforms,AI Frameworks,AI Tools and Models,Industry References
