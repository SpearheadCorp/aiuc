# ── AIUC — Environment Variables Reference (Everpure / PureStorage deployment) ─
# Copy this file to .env.local for local development and fill in real values.
# .env.local is gitignored — never commit real credentials.
# Lambda runtime variables are set in the AWS Lambda Console, not here.

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite build-time — prefix VITE_)
# These are baked into the compiled frontend bundle at npm run build time.
# ─────────────────────────────────────────────────────────────────────────────

# Okta OIDC — fetched at runtime via /api/okta-config; NOT required for prod build
VITE_OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default
VITE_OKTA_CLIENT_ID=0oaXXXXXXXXXXXXXXXXX

# Local dev only — Vite proxies /api/* to this URL
VITE_API_BASE_URL=http://localhost:3001

# Optional: deploy at a sub-path (e.g. behind an ALB at /app/aiuc)
# Leave unset for standard Lambda Function URL deployment at root /
# VITE_BASE_PATH=/app/aiuc

# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEV — OpenAI API key for embedding generation and AI search
# Use a unique name (OPENAI_API_KEY_N) to avoid conflicts with any system-level
# OPENAI_API_KEY that may already be set in your shell environment.
# In production, the key is fetched from AWS Secrets Manager automatically.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY_N=sk-proj-...your-openai-key-here...

# ─────────────────────────────────────────────────────────────────────────────
# LAMBDA RUNTIME — set in AWS Lambda Console (not in this file for production)
# Documented here for reference only.
# ─────────────────────────────────────────────────────────────────────────────

# S3 / Storage
# BUCKET_NAME=your-s3-bucket-name
# S3_REGION=us-east-2
# DIST_PREFIX=dist

# S3 keys for pre-computed embeddings (pure_ prefix separates Everpure files
# from Spearhead files that share the same bucket)
# USE_CASES_EMBEDDINGS_KEY=pure_use_cases_embeddings.json
# INDUSTRY_EMBEDDINGS_KEY=pure_industry_use_cases_embeddings.json

# Okta authentication (Lambda JWT verification)
# OKTA_ISSUER=https://your-okta-domain.okta.com/oauth2/default
# OKTA_AUDIENCE=api://default
# AIUC_SECRET_NAME=aiuc/everpure   # AWS Secrets Manager secret name
#   Secret JSON shape: { "OKTA_CLIENT_ID": "...", "EVERPURE_OPENAI_API_KEY": "sk-..." }

# AI search feature flag
# Set to "false" to disable semantic search and fall back to keyword matching only
# ENABLE_AI_SEARCH=true

# Search rate limiting — protect OpenAI costs (applied per-user, per Lambda container)
# Max requests per rolling window (default: 10)
# SEARCH_RATE_LIMIT_MAX=10
# Rolling window duration in milliseconds (default: 60000 = 1 minute)
# SEARCH_RATE_LIMIT_WINDOW_MS=60000

# Sub-path prefix (only when app is deployed behind a reverse proxy at a sub-path)
# BASE_PATH=/app/aiuc
